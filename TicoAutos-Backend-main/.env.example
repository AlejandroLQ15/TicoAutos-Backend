# Copia este archivo como .env y completa los valores.
# No subas el .env a Git (debe estar en .gitignore).

# Obligatorio: clave para firmar y verificar tokens JWT (login).
JWT_SECRET=tu_clave_secreta_aqui

# Opcional: URI de MongoDB. Si no se define, se usa mongodb://127.0.0.1:27017/ticoautos
# MONGO_URI=mongodb://127.0.0.1:27017/ticoautos
# MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/ticoautos

# Opcional: puerto del servidor. Por defecto 3000.
# PORT=3000
